plugin location="__YAZELIX_RUNTIME_ZJSTATUS_PLUGIN_URL__" {
    format_left   "{mode} {tabs}"
    format_center ""
    format_right  "__YAZELIX_RUNTIME_STYLE_SESSION__{session}__YAZELIX_RUNTIME_WIDGET_TRAY__ __YAZELIX_RUNTIME_CUSTOM_TEXT____YAZELIX_RUNTIME_STYLE_BRAND__YZX {command_version} " // {datetime}
    format_hide_on_overlength "true"
    format_precedence "lrc"
    format_space  ""

    border_enabled  "false"

    mode_normal  "__YAZELIX_RUNTIME_MODE_NORMAL__ NORMAL "
    mode_tmux    "__YAZELIX_RUNTIME_MODE_TMUX__ TMUX "
    mode_session "__YAZELIX_RUNTIME_MODE_SESSION__ SESSION "
    mode_scroll  "__YAZELIX_RUNTIME_MODE_SCROLL__ SCROLL "

__YAZELIX_RUNTIME_TAB_LABELS__
    tab_separator ""
__YAZELIX_RUNTIME_TAB_RENAME__
    tab_sync_indicator       "<> "
    tab_fullscreen_indicator "[] "
    tab_floating_indicator   "__YAZELIX_RUNTIME_FLOATING_INDICATOR__"
    tab_bell_indicator       ""
    tab_flashing_bell_indicator ""
    tab_display_count "6"
    tab_truncate_start_format "__YAZELIX_RUNTIME_STYLE_TAB_TRUNCATE__< +{count} ... "
    tab_truncate_end_format   "__YAZELIX_RUNTIME_STYLE_TAB_TRUNCATE__... +{count} > "

    datetime        "__YAZELIX_RUNTIME_STYLE_DATETIME__ {format} "
    datetime_format "%H:%M %d/%m"

    pipe_workspace_format "__YAZELIX_RUNTIME_STYLE_WORKSPACE__{output}"

    command_claude_usage_command "__YAZELIX_RUNTIME_WIDGET_BIN__ claude --display __YAZELIX_RUNTIME_CLAUDE_USAGE_DISPLAY__ --periods __YAZELIX_RUNTIME_CLAUDE_USAGE_PERIODS__"
    command_claude_usage_format "__YAZELIX_RUNTIME_STYLE_USAGE__{stdout}"
    command_claude_usage_interval "10"

    command_codex_usage_command "__YAZELIX_RUNTIME_WIDGET_BIN__ codex --display __YAZELIX_RUNTIME_CODEX_USAGE_DISPLAY__ --periods __YAZELIX_RUNTIME_CODEX_USAGE_PERIODS__"
    command_codex_usage_format "__YAZELIX_RUNTIME_STYLE_USAGE__{stdout}"
    command_codex_usage_interval "10"

    command_opencode_go_usage_command "__YAZELIX_RUNTIME_WIDGET_BIN__ opencode_go --display __YAZELIX_RUNTIME_OPENCODE_GO_USAGE_DISPLAY__ --periods __YAZELIX_RUNTIME_OPENCODE_GO_USAGE_PERIODS__"
    command_opencode_go_usage_format "__YAZELIX_RUNTIME_STYLE_USAGE__{stdout}"
    command_opencode_go_usage_interval "10"

    command_cpu_command "__YAZELIX_RUNTIME_WIDGET_BIN__ cpu"
    command_cpu_format " __YAZELIX_RUNTIME_STYLE_SYSTEM_USAGE__[cpu {stdout}]"
    command_cpu_interval "5"

    command_ram_command "__YAZELIX_RUNTIME_WIDGET_BIN__ ram"
    command_ram_format " __YAZELIX_RUNTIME_STYLE_SYSTEM_USAGE__[ram {stdout}]"
    command_ram_interval "5"

    command_version_command "__YAZELIX_RUNTIME_WIDGET_BIN__ version --runtime-dir __YAZELIX_RUNTIME_DIR__"
    command_version_format "{stdout}"
    command_version_interval "3600"
}
