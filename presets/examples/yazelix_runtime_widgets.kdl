// These snippets require the full Yazelix runtime and its cached status helpers.
// Workspace, version, and integrated tabs are Yazelix-only. Other widgets are bar-owned commands.

format_left "{mode} {command_yazelix_tabs}"

command_yazelix_tabs_command "yazelix_zellij_bar_widget tabs --appearance dark --mode full"
command_yazelix_tabs_format "{stdout}"
command_yazelix_tabs_rendermode "dynamic"
command_yazelix_tabs_interval "1"

format_right "#[fg=#ff0088,bold]{session}{pipe_workspace}{command_claude_usage}{command_codex_usage}{command_opencode_go_usage}{command_cpu}{command_ram} #[fg=#00ccff,bold]YZX {command_version} "

pipe_workspace_format "#[fg=#00ff88,bold]{output}"

command_claude_usage_command "yazelix_zellij_bar_widget claude --display both"
command_claude_usage_format "#[fg=#bb88ff,bold]{stdout}"
command_claude_usage_interval "10"

command_codex_usage_command "yazelix_zellij_bar_widget codex --display quota"
command_codex_usage_format "#[fg=#bb88ff,bold]{stdout}"
command_codex_usage_interval "10"

command_opencode_go_usage_command "yazelix_zellij_bar_widget opencode_go --display both"
command_opencode_go_usage_format "#[fg=#bb88ff,bold]{stdout}"
command_opencode_go_usage_interval "10"

command_cpu_command "yazelix_zellij_bar_widget cpu"
command_cpu_format " #[fg=#ff6600][cpu {stdout}]"
command_cpu_interval "5"

command_ram_command "yazelix_zellij_bar_widget ram"
command_ram_format " #[fg=#ff6600][ram {stdout}]"
command_ram_interval "5"

command_version_command "yazelix_zellij_bar_widget version --runtime-dir __YAZELIX_RUNTIME_DIR__"
command_version_format "{stdout}"
command_version_interval "3600"
